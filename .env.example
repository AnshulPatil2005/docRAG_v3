# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── Qdrant ───
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documents
QDRANT_DISTANCE_METRIC=cosine
QDRANT_BATCH_SIZE=128

# ─── Neo4j ───
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# ─── LLM (OpenRouter only) ───
# OPENROUTER_API_KEY is optional here: if left unset, the server has no
# default key and every request must supply its own (e.g. entered in the
# frontend header) -- see docs/decisions.md.
OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_MODEL=meta-llama/llama-3-8b-instruct:free

# ─── Embeddings ───
# EMBEDDING_PROVIDER: "local" (sentence-transformers, default) | "openai" | "stub" (tests/dev only)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64
# OPENAI_API_KEY=sk-xxxxx   # required only if EMBEDDING_PROVIDER=openai

# ─── RAG ───
RAG_TOP_K=5
MAX_CONTEXT_TOKENS=4096
CHUNK_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# ─── Celery ───
CELERY_CONCURRENCY=2

# ─── Upload ───
MAX_UPLOAD_MB=50
UPLOAD_DIR=/app/uploads
